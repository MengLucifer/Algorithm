const v = document.querySelector('video');
if (v.readyState >= 1) {
  console.log(v.videoWidth, v.videoHeight);
} else {
  v.addEventListener('loadedmetadata', () => {
    console.log(v.videoWidth, v.videoHeight);
  });
}


document.querySelectorAll('video').forEach((v, i) => {
  console.log(`Video ${i}: ${v.videoWidth}x${v.videoHeight}`);
});
